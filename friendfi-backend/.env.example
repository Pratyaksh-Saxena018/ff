# FriendFi v4.1 Backend - Environment Configuration
# Copy to .env and fill in your values

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/friendfi?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# Redis (for pub/sub + session + BullMQ)
REDIS_URL=redis://localhost:6379

# AI Providers
OPENAI_KEY=sk-...
GEMINI_KEY=...
CLAUDE_KEY=sk-ant-...
PERPLEXITY_KEY=pplx-...
GROQ_KEY=gsk-...

# Server
PORT=4000
NODE_ENV=development

# CORS (comma-separated origins for Vercel frontend)
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Dispute / Voting
VOTE_TIMER_SECONDS=60
MIN_QUORUM_VOTES=3

# Karma defaults
INITIAL_KARMA=500
KARMA_FORGIVE_BULLY=5
KARMA_SANCTION_BULLY=-15
KARMA_JUROR_ALIGNED=5
KARMA_JUROR_MISALIGNED=-1
REPEAT_OFFENDER_MULTIPLIER=1.5

# Toxicity threshold (0-100) to trigger dispute
TOXICITY_THRESHOLD=85

# AI timeouts (ms)
AI_TIMEOUT_MS=15000
AI_MAX_RETRIES=2
